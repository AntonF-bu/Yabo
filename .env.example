# =============================================================================
# Yabo Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# .env.local is gitignored — never commit real keys.
# =============================================================================

# --- Clerk Authentication ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic Claude (for AI narrative analysis) ---
ANTHROPIC_API_KEY=

# --- Finnhub (optional: live quotes on ticker detail pages) ---
NEXT_PUBLIC_FINNHUB_API_KEY=

# --- Polygon.io (optional: live options pricing with Greeks) ---
# Starter plan ($29/mo) — enables bid/ask/mid, delta/gamma/theta/vega, IV, OI
# Without this key, options fall back to last transaction prices
POLYGON_API_KEY=
